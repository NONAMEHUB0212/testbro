# Telegram API credentials (required)
API_ID=12345678
API_HASH=your_api_hash_here
PHONE_NUMBER=+66812345678
WALLET_NUMBER=0812345678
WALLET_NAME=กระเป๋าหลัก

# Optional: protect web dashboard with password (user: admin)
ADMIN_PASSWORD=your_secure_password

# Optional: MongoDB URI for persistent session (recommended)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/

# Optional: Webhook URL(s) for notifications (Discord, etc.) – multiple URLs separated by commas
WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy,https://another.webhook.url

# Optional: if you don't use MongoDB, you can store session string here
# SESSION_STRING=your_session_string_from_first_login
